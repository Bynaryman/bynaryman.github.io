---
layout: default
---
{% unless site.data.resume %}
  <div class="post">
    <header class="post-header">
      <h1 class="post-title">
        {{ page.title }}
        {% if page.cv_pdf %}
          <a
            href="{{ page.cv_pdf | prepend: 'assets/pdf/' | relative_url}}"
            target="_blank"
            rel="noopener noreferrer"
            class="float-right"
            ><i class="fa-solid fa-file-pdf"></i
          ></a>
        {% endif %}
      </h1>
      {% if page.description %}
        <p class="post-description">{{ page.description }}</p>
      {% endif %}
    </header>

    <article>
      <div class="cv">
        {% for entry in site.data.cv %}
          <a class="anchor" id="{{ entry.title }}"></a>
          <div class="card mt-3 p-3">
            <h3 class="card-title font-weight-medium">{{ entry.title }}</h3>
            <div>
              {% if entry.type == 'list' %}
                {% include cv/list.liquid %}
              {% elsif entry.type == 'map' %}
                {% include cv/map.liquid %}
              {% elsif entry.type == 'nested_list' %}
                {% include cv/nested_list.liquid %}
              {% elsif entry.type == 'time_table' %}
                {% include cv/time_table.liquid %}
              {% elsif entry.type == 'list_groups' %}
                {% include cv/list_groups.liquid %}
              {% else %}
                {{ entry.contents }}
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    </article>
  </div>
{% else %}
  <div class="post">
    <header class="post-header">
      <h1 class="post-title">
        {{ page.title }}
        {% if page.cv_pdf %}
          <a
            href="{{ page.cv_pdf | prepend: 'assets/pdf/' | relative_url}}"
            target="_blank"
            rel="noopener noreferrer"
            class="float-right"
            ><i class="fa-solid fa-file-pdf"></i
          ></a>
        {% endif %}
      </h1>
      {% if page.description %}
        <p class="post-description">{{ page.description }}</p>
      {% endif %}
    </header>

    <article>
      <div class="cv">
        {% for section in site.jsonresume %}
          {% assign items = site.data.resume[section] %}
          {% if items == nil or items.size == 0 %}
            {% continue %}
          {% endif %}
          <a class="anchor" id="{{ section }}"></a>
          <div class="card mt-3 p-3">
            <h3 class="card-title font-weight-medium">
              {% case section %}
                {% when 'basics' %}Basics
                {% when 'work' %}Experience
                {% when 'teaching' %}Teaching
                {% when 'education' %}Education
                {% when 'journals' %}International Peer-reviewed Journals
                {% when 'conference_papers' %}International Peer-reviewed Conference Papers
                {% when 'tutorials' %}Tutorials, Workshops &amp; Demos
                {% when 'contributions' %}Contributions to Publications
                {% when 'posters' %}Poster Presentations
                {% when 'invited_talks' %}Invited Talks &amp; Seminars
                {% when 'academic_reviewing' %}Conference Peer Reviewing
                {% when 'conference_organization' %}Conference Organization Experience
                {% when 'academic_summer_schools' %}Academic Summer Schools and Workshops
                {% when 'internship_mentoring' %}Internship Mentoring
                {% when 'projects' %}Technology Development: Software &amp; Hardware
                {% when 'skills' %}Skills
                {% when 'languages' %}Languages
                {% else %}{{ section | replace: '_', ' ' | capitalize }}
              {% endcase %}
            </h3>
            <div>
              {% case section %}
                {% when 'basics' %}
                  {% include resume/basics.liquid %}
                {% when 'education' %}
                  {% include resume/education.liquid %}
                {% when 'work' %}
                  {% include resume/work.liquid %}
                {% when 'teaching' %}
                  {% include resume/work.liquid %}
                {% when 'projects' %}
                  {% include resume/projects.liquid %}
                {% when 'skills' %}
                  {% include resume/skills.liquid %}
                {% when 'languages' %}
                  {% include resume/languages.liquid %}
                {% when 'journals' %}
                  {% include resume/publications.liquid %}
                {% when 'conference_papers' %}
                  {% include resume/publications.liquid %}
                {% when 'tutorials' %}
                  {% include resume/publications.liquid %}
                {% when 'contributions' %}
                  {% include resume/publications.liquid %}
                {% when 'posters' %}
                  {% include resume/publications.liquid %}
                {% when 'invited_talks' %}
                  {% include resume/publications.liquid %}
                {% when 'academic_reviewing' %}
                  {% include resume/publications.liquid %}
                {% when 'conference_organization' %}
                  {% include resume/publications.liquid %}
                {% when 'academic_summer_schools' %}
                  {% include resume/publications.liquid %}
                {% when 'internship_mentoring' %}
                  {% include resume/publications.liquid %}
                {% when 'volunteer' %}
                  {% include resume/volunteer.liquid %}
                {% when 'awards' %}
                  {% include resume/awards.liquid %}
                {% when 'certificates' %}
                  {% include resume/certificates.liquid %}
                {% when 'interests' %}
                  {% include resume/interests.liquid %}
                {% when 'references' %}
                  {% include resume/references.liquid %}
              {% endcase %}
            </div>
          </div>
        {% endfor %}
      </div>
    </article>
  </div>
{% endunless %}
