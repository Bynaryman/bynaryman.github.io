<ul class="card-text font-weight-light list-group list-group-flush">
  {% for content in data[1] %}
    <li class="list-group-item">
      <div class="row">
        {% if content.date and content.date != '' %}
          {% assign date = content.date | split: '-' | join: '.' %}
        {% else %}
          {% assign date = '' %}
        {% endif %}
        {% assign date_text = date | strip %}
        {% if date_text != '' %}
          <div class="cv-date-column col-12 col-md-3 text-md-center">
            <span class="badge cv-date-badge font-weight-bold danger-color-dark text-uppercase align-middle">{{ date_text }}</span>
          </div>
        {% endif %}
        <div class="{% if date_text != '' %}cv-content-column col-12 col-md-9{% else %}cv-content-column cv-content-column-full col-12{% endif %} mt-2 mt-md-0">
          <h6 class="title font-weight-bold ml-1 ml-md-4">
            <a href="{{ content.url }}">{{ content.title }}</a>
          </h6>
          <h6 class="ml-1 ml-md-4" style="font-size: 0.95rem">{{ content.awarder }}</h6>
          <h6 class="ml-1 ml-md-4" style="font-size: 0.95rem; font-style: italic">{{ content.summary }}</h6>
        </div>
      </div>
    </li>
  {% endfor %}
</ul>
